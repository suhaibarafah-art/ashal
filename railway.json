{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd agents-team && npm install"
  },
  "deploy": {
    "startCommand": "node agents-team/chief-executive-agent.js --server",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
