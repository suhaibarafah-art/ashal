generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Neon PostgreSQL (production on Vercel)
  // Set DATABASE_URL in Vercel env vars to your Neon connection string:
  //   postgresql://user:pass@ep-ancient-firefly-14321349.neon.tech/neondb?sslmode=require
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// 1. عراف الهبّة (The Predictive Oracle)
model PredictiveOracle {
  id              String   @id @default(uuid())
  keyword         String   @unique
  source          String   // e.g., Pinterest, Xiaohongshu, Reddit
  saudiRelevance  Float    // Score 0.0 to 1.0 mapping global to local trend
  ctrTestResult   Float?   // Click-through rate from the auto $5 Meta test
  status          String   @default("TESTING") // TESTING, APPROVED, REJECTED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  products        Product[]
}

// 2. وكالة الإبداع الآلية (Virtual Influencers & Marketing)
model AIInfluencerCampaign {
  id              String   @id @default(uuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  aiModelType     String   // e.g., Saudi Male, Saudi Female (Virtual)
  backgroundScene String   // e.g., Riyadh Majlis, AlUla Desert
  generatedMedia  String? // Joined URLs or JSON string
  platform        String   // Snapchat, TikTok, Meta
  roas            Float    @default(0.0)
  createdAt       DateTime @default(now())
}

// 3. محرك الثروة المستدامة (30-Year Wealth Engine)
model WealthPortfolio {
  id              String   @id @default(uuid())
  date            DateTime @unique @default(now())
  totalNetProfit  Float    // Net profit for the day ends in .99
  
  marketingReinvest Float  // 40%
  longTermInvest    Float  // 40% (Stocks/Funds)
  aiDevelopmentFund Float  // 20%
  
  wealthProjection30Y Float // The forecasted value over 30 years with compound interest
  createdAt         DateTime @default(now())
}

// 4. العمليات اللوجستية السيادية (Self-Optimizing Logistics)
model LogisticBot {
  id              String   @id @default(uuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id])
  chosenCourier   String   // Aramex, SMSA, DHL (dynamically chosen)
  shippingCost    Float
  whiteLabeled    Boolean  @default(true) // Custom packaging requested from supplier
  returnRequested Boolean  @default(false)
  autoRefunded    Boolean  @default(false)
  createdAt       DateTime @default(now())
}

// 5. الفواتير الإلكترونية ZATCA (Official Saudi E-Invoicing)
model EInvoiceZATCA {
  id                  String   @id @default(uuid())
  orderId             String   @unique
  order               Order    @relation(fields: [orderId], references: [id])
  cryptographicStamp  String   // ZATCA Phase 2 requirement (Hash)
  qrCodeData          String   // Base64 TLV Encoded string for Saudi VAT
  zatcaStatus         String   // CLEARED, REPORTED
  issuedAt            DateTime @default(now())
}

// ----------------------------------------------------
// Core Infrastructure (Products, Orders, Conversations)
// ----------------------------------------------------

model Product {
  id              String   @id @default(uuid())
  titleEn         String   @unique
  titleAr         String
  descAr          String
  baseCost        Float
  shippingCost    Float
  finalPrice      Float    // (baseCost + shippingCost) * 1.30 * 1.15 rounded to .99

  // Phase 2: Supply Chain fields
  imageUrl        String   @default("")   // High-res supplier image URL
  category        String   @default("")   // Product category
  supplier        String   @default("cj") // "mkhazen" | "cj" | "zendrop"
  stockLevel      Int      @default(0)    // Live stock from supplier
  weightKg        Float    @default(0.0)  // Shipping weight
  dimensions      String   @default("")   // "LxWxH cm" string
  supplierSku     String   @default("")   // External supplier SKU/ID

  isHidden        Boolean  @default(false) // Set true by Guardian when stock=0
  adCopyTikTok    String   @default("")
  adCopySnap      String   @default("")
  adCopyIG        String   @default("")
  marginPct       Float    @default(0.0)   // Calculated margin %

  oracleId        String?
  oracleReference PredictiveOracle? @relation(fields: [oracleId], references: [id])

  campaigns        AIInfluencerCampaign[]
  orders           Order[]
  marketingContent MarketingContent[]
  queueEntries     AgentTaskQueue[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Phase 4: Coupon Engine — SAVE10 (10% off) | ROYAL20 (20% off)
model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique    // e.g., "SAVE10", "ROYAL20"
  discountPct     Float               // 0.10 = 10%, 0.20 = 20%
  isActive        Boolean  @default(true)
  usageCount      Int      @default(0)
  maxUsage        Int      @default(1000)
  orders          Order[]
  createdAt       DateTime @default(now())
}

// Phase 5: System log entries (stealth mode — no Telegram/Email)
model SystemLog {
  id        String   @id @default(uuid())
  level     String   @default("INFO") // INFO | WARN | ERROR | SUCCESS
  source    String                    // e.g., "payment", "supply-chain", "webhook"
  message   String
  metadata  String   @default("")     // JSON string of extra data
  createdAt DateTime @default(now())
}

model Order {
  id                  String   @id @default(uuid())
  productId           String
  product             Product  @relation(fields: [productId], references: [id])
  customerName        String   @default("")
  customerPhone       String
  customerCity        String
  customerAddress     String   @default("")
  totalAmount         Float
  discountAmount      Float    @default(0.0)  // Coupon discount applied
  paymentStatus       String   // PENDING | PAID | FULFILLING | SHIPPED | DELIVERED
  moyasarPaymentId    String   @default("")
  trackingNumber      String   @default("")
  couponId            String?
  coupon              Coupon?  @relation(fields: [couponId], references: [id])

  logistics           LogisticBot?
  zatcaInvoice        EInvoiceZATCA?
  conversation        ConversationalSession?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// The Meta-Storefront (Voice-AI / Chatbot sessions)
model ConversationalSession {
  id              String   @id @default(uuid())
  sessionId       String   @unique
  orderId         String?  @unique
  order           Order?   @relation(fields: [orderId], references: [id])
  conversationLog String   // Stringified JSON
  preferenceTags  String?  // Comma-separated tags
  createdAt       DateTime @default(now())
}

// Marketing Content — AI Writer output, reviewed by team before publishing
model MarketingContent {
  id          String   @id @default(uuid())
  dayIndex    Int      // 0=Sun … 6=Sat
  weekOf      String   // "YYYY-MM-DD" of the Sunday of this week
  contentType String   // Unboxing | The Look | Detail Shot | etc.
  goal        String   // إثارة الفضول | رفع قيمة السلة | ...
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  captions    String   // JSON: string[]  (3 AI-generated captions)
  hashtags    String   @default("")
  status      String   @default("DRAFT") // DRAFT | APPROVED | PUBLISHED
  teamNotes   String   @default("")
  supplierRef String   @default("") // supplier SKU / product link used
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// A/B Copy Testing — Summer Season 2026
model VariantEvent {
  id          String   @id @default(uuid())
  sessionId   String
  productId   String
  variantKey  String   // "royal" | "modern" | "emotional"
  event       String   // "view" | "add_to_cart"
  createdAt   DateTime @default(now())

  @@index([productId, variantKey, event])
  @@index([createdAt])
}

// Abandoned Cart Recovery System
model AbandonedCart {
  id           String    @id @default(uuid())
  email        String?
  phone        String?
  cartData     String    // JSON representations of products
  status       String    @default("pending") // pending, discount_sent, recovered
  remindedAt   DateTime?
  discountCode String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─── TITAN-10: Shared Agent State ────────────────────────────────────────────

// AgentTaskQueue — central shared state for the full TITAN-10 pipeline
// Statuses flow: PENDING_CRITIC → PENDING_COPY → PENDING_STRATEGY → READY_TO_PUBLISH → ARCHIVED
model AgentTaskQueue {
  id           String   @id @default(uuid())

  // Raw product data from Scout
  cjProductId  String
  titleEn      String
  titleAr      String   @default("")
  descAr       String   @default("")
  imageUrl     String
  baseCost     Float
  shippingCost Float
  marginPct    Float    @default(0.0)  // Calculated: (finalPrice - cost - ship) / finalPrice

  // Generated by Agents
  adCopyTikTok String   @default("")
  adCopySnap   String   @default("")
  adCopyIG     String   @default("")

  // Link to published Product (after CEO pushes to store)
  productId    String?
  product      Product? @relation(fields: [productId], references: [id])

  // Pipeline state
  status       String   @default("PENDING_CRITIC")
  // PENDING_CRITIC | PENDING_COPY | PENDING_STRATEGY | READY_TO_PUBLISH | ARCHIVED
  errorLog     String   @default("")
  agentNotes   String   @default("")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([cjProductId])
}

// DailyReport — written by Agent 10 (Analyst) every 06:00 AM
model DailyReport {
  id               String   @id @default(uuid())
  date             DateTime @unique  // truncated to date (midnight UTC)
  totalRevenue     Float    @default(0)
  orderCount       Int      @default(0)
  conversionRate   Float    @default(0)   // orders / estimated visitors (from logs)
  syncSuccess      Int      @default(0)   // successfully synced orders
  syncFailed       Int      @default(0)
  newProducts      Int      @default(0)   // products published today
  archivedProducts Int      @default(0)   // products archived by Critic
  topProductId     String?
  topProductTitle  String   @default("")
  topProductRevenue Float   @default(0)
  createdAt        DateTime @default(now())
}
