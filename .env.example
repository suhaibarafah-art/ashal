# ══════════════════════════════════════════════════════════════════════════════
# ASHAL — Environment Variables
# Copy to .env and fill in real values before running locally or deploying.
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL on Neon / Supabase / Railway
DATABASE_URL=postgresql://user:password@host:5432/ashal?sslmode=require

# ── NextAuth v5 ───────────────────────────────────────────────────────────────
AUTH_SECRET=your-random-32-char-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Moyasar — Saudi payment gateway ──────────────────────────────────────────
# https://docs.moyasar.com
MOYASAR_API_KEY=moyasar_secret_key_goes_here
NEXT_PUBLIC_MOYASAR_PUBLISHABLE_KEY=moyasar_publishable_key_goes_here

# ── Tabby — Buy Now Pay Later ─────────────────────────────────────────────────
TABBY_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TABBY_MERCHANT_CODE=ashal

# ── Tamara — BNPL for Saudi market ───────────────────────────────────────────
TAMARA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAMARA_NOTIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend — Transactional email ──────────────────────────────────────────────
# Use "test" locally to mock emails in console
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=orders@ashal.sa

# ── Klaviyo — Email marketing flows ──────────────────────────────────────────
KLAVIYO_API_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KLAVIYO_LIST_ID=xxxxxxxx

# ── Twilio WhatsApp Business ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886

# ── Analytics Pixels ──────────────────────────────────────────────────────────
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=000000000000000
NEXT_PUBLIC_TIKTOK_PIXEL_ID=XXXXXXXXXXXXXXXXXXXXXXX

# ── Telegram — CEO alerts ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=0000000000:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100000000000

# ── Google Gemini — Agent AI ──────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── CJ Dropshipping API ───────────────────────────────────────────────────────
# https://developers.cjdropshipping.com
CJ_EMAIL=your-cj-account@email.com
CJ_PASSWORD=your-cj-api-password
CJ_ACCESS_TOKEN=

# ── AliExpress Affiliate API (fallback) ───────────────────────────────────────
ALIEXPRESS_APP_KEY=00000000
ALIEXPRESS_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── n8n (self-hosted on Railway) ──────────────────────────────────────────────
N8N_URL=https://n8n.your-railway-domain.railway.app
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your-strong-password-here
N8N_ENCRYPTION_KEY=your-32-char-encryption-key-here

# ── n8n → Next.js webhook ─────────────────────────────────────────────────────
N8N_TO_NEXTJS_SECRET=your-32-char-webhook-secret-here
NEXTJS_WEBHOOK_URL=https://ashal.vercel.app/api/webhooks/n8n

# ── Railway Agent Worker ──────────────────────────────────────────────────────
RAILWAY_AGENT_WEBHOOK_URL=https://agent-worker.railway.app/run
RAILWAY_AGENT_SECRET=your-32-char-agent-secret-here

# ── Vercel Cron Auth ──────────────────────────────────────────────────────────
CRON_SECRET=your-32-char-cron-secret-here

# ── Agent Behavior ────────────────────────────────────────────────────────────
AGENT_MAX_PRODUCTS=15
AGENT_MIN_SCORE=50
AGENT_DRY_RUN=false
DEFAULT_SUPPLIER_ID=

# ── Shipping (future) ─────────────────────────────────────────────────────────
# SMSA_USERNAME=
# SMSA_PASSWORD=
# SMSA_ENTITY=
# ARAMEX_USERNAME=
# ARAMEX_PASSWORD=
# ARAMEX_ACCOUNT_NUMBER=
# ARAMEX_ACCOUNT_PIN=
